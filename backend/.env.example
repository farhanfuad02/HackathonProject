# ------------------------------------------------------------------
# Office Electricity Monitor - backend configuration
# Copy this file to `.env` and fill in the values you need.
# Every value is optional - the server boots with sensible defaults
# and degrades gracefully when an integration is not configured.
# ------------------------------------------------------------------

# HTTP port for the REST API + Socket.IO server
PORT=4000

# MongoDB connection string.
# If MongoDB is unreachable the server keeps running with the
# in-memory store only (state is lost on restart).
MONGODB_URI=mongodb://127.0.0.1:27017/office-monitor

# Discord bot token (from https://discord.com/developers/applications).
# Leave empty to run the backend without the bot.
DISCORD_BOT_TOKEN=

# Channel ID where the bot proactively posts alert messages (bonus feature).
# Leave empty to disable proactive alert posts.
DISCORD_ALERT_CHANNEL_ID=

# Anthropic API key - used to generate friendly, conversational bot
# replies with Claude. Leave empty to fall back to built-in templates.
ANTHROPIC_API_KEY=

# Simulator tick interval in milliseconds
SIM_TICK_MS=5000
